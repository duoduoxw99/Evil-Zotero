# =============================================================================
# 将本文件复制为项目根目录的 .env 或 .env.local（勿提交真实密钥）。
# 仅 Express 服务端读取（server/env.ts 从仓库根加载）。
# =============================================================================

# 必填 — OpenAI API Key（仅此变量名有效；勿使用 OPENAI_KEY / API_KEY）
OPENAI_API_KEY=

# 可选 — 官方省略此项即使用 https://api.openai.com/v1
# 若填写，须为「无末尾斜杠」的 REST 根路径，例如：https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选 — 模型 ID（默认 gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini

# 可选 — 多组织 / 项目（官方文档 Authentication；sk-proj- 常需 OPENAI_PROJECT）
# OPENAI_ORGANIZATION=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_PROJECT=proj_xxxxxxxxxxxxxxxxxxxxxxxx

# 可选 — 若 401 且怀疑与组织/项目头冲突
# OPENAI_SKIP_ORG=1
# OPENAI_SKIP_PROJECT=1

# 可选 — 明确使用「非 OpenAI 官方」兼容网关时设为 1：请求头改为 api-key（非 Bearer）
# OPENAI_THIRD_PARTY=1

# 可选 — OPENAI_DEBUG=1 时启动多打一行脱敏 Key 前缀（永不打印完整 key）
# OPENAI_DEBUG=1

# 可选 — 本机出网代理（Clash 等）
# HTTPS_PROXY=http://127.0.0.1:7890
# SOCKS5_PROXY=socks5://127.0.0.1:7891

# OPENAI_NO_LOCAL_PROXY_FALLBACK=1
# OPENAI_CONNECT_TIMEOUT_MS=60000

PORT=8787

# AI 每浏览器会话成功调用上限（默认 10）
# AI_QUOTA_PER_USER=10

# CORS，生产请收紧
# AI_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Vite 代理到的 API 端口
# VITE_API_PORT=8787

# 前端构建时若 API 异源，设置完整 API 根（无尾斜杠）
# VITE_API_BASE_URL=
