# Copy to .env in the project root (never commit .env).
# Used only by the Express API server (server/index.ts).

OPENAI_API_KEY=

# Optional
PORT=8787
OPENAI_MODEL=gpt-4o-mini

# Comma-separated browser origins for CORS, or * for any origin (not recommended in production).
# AI_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# If the Vite dev server API proxy should target a different port:
# VITE_API_PORT=8787

# Production / custom deploy: full base URL of the API (no trailing slash).
# Build the frontend with: VITE_API_BASE_URL=https://your-api.example.com
# Leave unset for local dev / preview when using same-origin /api proxy.
# VITE_API_BASE_URL=
